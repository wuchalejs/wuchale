{
    "name": "@wuchale/sv",
    "description": "sv add-on for @wuchale/sv",
    "version": "0.0.1",
    "type": "module",
    "license": "MIT",
    "scripts": {
        "demo-create": "sv create demo --types ts --template minimal --no-add-ons --no-install",
        "demo-add": "npm run build && sv add file:../ --cwd demo --no-git-check --no-install",
        "demo-add:ci": "npm run build && sv add 'file:../=languages:en,es+generation:yes' --cwd demo --no-git-check --no-download-check --no-install",
        "build": "tsc",
        "prepublishOnly": "npm run build",
        "test": "node --import ../wuchale/testing/resolve.ts --test"
    },
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "default": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "sv": "^0.15.3"
    },
    "devDependencies": {
        "@sveltejs/sv-utils": "latest",
        "@types/node": "^25.5.2",
        "sv": "^0.15.3",
        "typescript": "^6.0.3"
    },
    "keywords": [
        "sv-add",
        "svelte",
        "sveltekit",
        "i18n",
        "internationalization",
        "wuchale"
    ],
    "homepage": "https://wuchale.dev/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wuchalejs/wuchale.git"
    },
    "bugs": {
        "url": "https://github.com/wuchalejs/wuchale/issues"
    }
}
