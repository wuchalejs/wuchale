{
    "name": "@wuchale/astro",
    "version": "0.4.4",
    "description": "Wuchale i18n adapter for Astro files",
    "scripts": {
        "dev": "tsc --watch",
        "build": "tsc",
        "test": "node --import ../wuchale/testing/resolve.ts --test"
    },
    "keywords": [
        "i18n",
        "internationalization",
        "translation",
        "gettext",
        "astro",
        "withastro",
        "vite",
        "po",
        "vite-plugin",
        "compile-time",
        "ast",
        "translation-tooling",
        "multilingual",
        "localization",
        "l10n",
        "automatic-i18n"
    ],
    "files": [
        "dist",
        "src/loaders"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./runtime.js": {
            "types": "./dist/runtime.d.ts",
            "default": "./dist/runtime.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wuchalejs/wuchale.git"
    },
    "homepage": "https://wuchale.dev",
    "bugs": "https://github.com/wuchalejs/wuchale/issues",
    "author": "K1DV5",
    "license": "MIT",
    "dependencies": {
        "@astrojs/compiler": "^4",
        "@sveltejs/acorn-typescript": "^1.0.11",
        "acorn": "^8.17.0",
        "wuchale": "^0.25.6"
    },
    "devDependencies": {
        "@types/node": "~24.13.3",
        "typescript": "^7.0.2"
    },
    "type": "module"
}
